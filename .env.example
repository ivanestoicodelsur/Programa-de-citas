# ── Server ────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── CORS — dominio(s) del frontend React (sin trailing slash, separados por coma) ──
FRONTEND_URL=https://gofixcompanymiami.com

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=cambia-esto-por-una-clave-segura-larga-aleatoria-de-64-chars
JWT_EXPIRES_IN=7d

# ── Database ─────────────────────────────────────────────
# SQLite (montar /app/data como volumen en EasyPanel)
SQL_DIALECT=sqlite
SQL_STORAGE=./data/repair.sqlite

# MongoDB (opcional — auditoría. Dejar vacío para usar modo en memoria)
# MONGODB_URI=mongodb://user:pass@host:27017/repair_inventory
MONGODB_URI=

# ── Admin user seed (idempotente — crea admin solo si no existe) ───
SEED_ADMIN_NAME=Administrador
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=CambiaMeEnProduccion123!
SEED_ADMIN_SCOPE=central

# ── AI Chat ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
# false = asistente IA desactivado en landing pública (recomendado)
# true  = activa el botón flotante del chat en GoFix
ENABLE_PUBLIC_AI_ASSISTANT=false

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# URL a la que Stripe redirige tras pago exitoso
PORTAL_URL=https://gofixcompanymiami.com/portal

# ── Google Sheets (opcional — sync inventario) ────────────
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEETS_SPREADSHEET_IDS=12UTXjuDD5uG_dcpXxNhrq_AtxQ9zEwzPd6ESWiDof3U,...
GOOGLE_SHEETS_LABELS=Apple,Samsung,Xiaomi,Motorola,LG,Huawei,Google Pixel
GOOGLE_SHEETS_SPREADSHEET_ID=12UTXjuDD5uG_dcpXxNhrq_AtxQ9zEwzPd6ESWiDof3U
GOOGLE_SHEETS_RANGE=
