# Server
PORT=4000
NODE_ENV=production

# CORS - set to your actual frontend domain (no trailing slash)
FRONTEND_URL=https://tudominio.com

# JWT - use a long random string in production
JWT_SECRET=cambia-esto-por-una-clave-segura-larga-aleatoria
JWT_EXPIRES_IN=1d

# Database - SQLite (mount /app/data as volume in EasyPanel)
SQL_DIALECT=sqlite
SQL_STORAGE=./data/repair.sqlite

# MongoDB (optional - for audit logs, can leave blank)
# MONGODB_URI=mongodb://user:pass@host:27017/repair_inventory

# AI Chat
ANTHROPIC_API_KEY=sk-ant-api03-...
# Asistente IA público en landing GoFix (false = desactivado, true = activo)
ENABLE_PUBLIC_AI_ASSISTANT=false

# Portal URL (para redirección post-checkout Stripe)
PORTAL_URL=https://gofixlibros.com/portal

# Admin user (created on first boot if not exists)
SEED_ADMIN_NAME=Administrador
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=CambiaMeEnProduccion123!
SEED_ADMIN_SCOPE=central

# Google Sheets sync
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEETS_SPREADSHEET_IDS=12UTXjuDD5uG_dcpXxNhrq_AtxQ9zEwzPd6ESWiDof3U,...
GOOGLE_SHEETS_LABELS=Apple,Samsung,Xiaomi,Motorola,LG,Huawei,Google Pixel
GOOGLE_SHEETS_SPREADSHEET_ID=12UTXjuDD5uG_dcpXxNhrq_AtxQ9zEwzPd6ESWiDof3U
GOOGLE_SHEETS_RANGE=
